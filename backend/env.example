# Скопируйте этот файл в `.env` (cp env.example .env) и заполните значения.
#
# --- Yandex AI Studio (LLM) ---
# Ключ и folder id приходят капитану письмом. Без них система работает в
# деградированном режиме (диагноз + RAG + шаблонные гипотезы), но не падает.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# OpenAI-совместимый эндпоинт Yandex AI Studio
LLM_BASE_URL=https://llm.api.cloud.yandex.net/v1
LLM_MODEL_ID=qwen3-235b-a22b-fp8
LLM_FALLBACK_MODEL_ID=gpt-oss-120b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4000

# Vision-модель: расшифровка изображений схем/регламентов (тот же эндпоинт и ключ).
# Reasoning-модель — щедрый лимит токенов вмещает и рассуждения, и ответ.
VISION_MODEL_ID=qwen3.6-35b-a3b
VISION_MAX_TOKENS=12000

# --- Семантический слой RAG (опционально) ---
EMBEDDINGS_ENABLED=true
EMBEDDINGS_BACKEND=yandex          # yandex | local
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3

# --- Пути ---
# DATA_DIR указывает на папку с материалами организаторов (уровнем выше репозитория)
DATA_DIR=../DATA

# Разграничение доступа: если задать, все /api/* требуют заголовок X-API-Key
APP_ACCESS_KEY=

# Референсные цены металлов для экономической оценки, USD/т (0 = отключить)
METAL_PRICE_28_USD_T=16500
METAL_PRICE_29_USD_T=9200
